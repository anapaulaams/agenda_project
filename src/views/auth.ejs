<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>Login - Cadastro</title>
</head>
<body class="container py-4 d-flex justify-content-center align-items-center vh-100 bg-light">

    <div class="card p-4" style="width: 400px;">


        <h1 class="text-center mb-4">Sistema Clínica</h1>

        <ul class="nav nav-tabs mb-3" id="myTab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#login">Acessar</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#cadastro">Cadastrar</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#suporte">Suporte</button>
            </li>
        </ul>

        <div class="tab-content mt-3">

            <!-- LOGIN -->
            <div class="tab-pane fade show active" id="login">
                <h2>Login</h2>
                <form class="needs-validation" novalidate>
                    <div class="form-floating mb-3">
                        <input class="form-control" type="text" id="usuario" placeholder=" " required>
                        <label for="usuario">Usuário</label>
                        <div class="invalid-feedback">Preencha o campo com o seu usuário</div>
                    </div>

                    <div class="form-floating mb-3">    
                        <input class="form-control" type="password" id="senha" placeholder=" " required>
                        <label for="senha">Senha</label>
                        <div class="invalid-feedback">Preencha o campo com a sua senha</div>
                    </div>

                    <a href="#" style="color:black;">Esqueci minha senha</a><br><br>
                    <button type="submit" class="btn btn-custom">Acessar</button>
                </form>
            </div>

            <!-- CADASTRO -->
            <div class="tab-pane fade" id="cadastro">
                <h2>Cadastro</h2>
                <form class="needs-validation" novalidate>
                    <div class="form-floating mb-3">
                        <input class="form-control" type="text" id="nome" placeholder=" " required>
                        <label for="nome">Nome</label>
                        <div class="invalid-feedback">Preencha o campo com o seu nome</div>
                    </div>

                    <div class="form-floating mb-3">
                        <input class="form-control" type="text" id="sobrenome" placeholder=" " required>
                        <label for="sobrenome">Sobrenome</label>
                        <div class="invalid-feedback">Preencha o campo com o seu sobrenome</div>
                    </div>

                    <div class="form-floating mb-3">
                        <input class="form-control" type="email" id="email" placeholder=" " required>
                        <label for="email">E-mail</label>
                        <div class="invalid-feedback">Preencha o campo com o seu e-mail</div>
                    </div>

                    <div class="form-floating mb-3">
                        <input class="form-control" type="number" id="cpf" placeholder=" " required>
                        <label for="cpf">CPF</label>
                        <div class="invalid-feedback">Preencha o campo com o seu CPF</div>
                    </div>

                    <button type="submit" class="btn btn-custom">Cadastrar</button>
                </form>
            </div>

            <!-- SUPORTE -->
            <div class="tab-pane fade" id="suporte">
                <h2>Suporte</h2>
                <h3>Fale conosco</h3>
                <form class="needs-validation" novalidate>
                    <div class="form-floating mb-3">
                        <input class="form-control" type="email" id="suporteEmail" placeholder=" " required>
                        <label for="suporteEmail">Digite seu E-mail</label>
                        <div class="invalid-feedback">Preencha o campo com o seu e-mail</div>
                    </div>

                    <div class="form-floating mb-3">
                        <input class="form-control" type="text" id="assunto" placeholder=" " required>
                        <label for="assunto">Assunto</label>
                        <div class="invalid-feedback">Preencha o campo com o assunto</div>
                    </div>

                    <button type="submit" class="btn btn-custom">Enviar</button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/script.js"></script>
</body>
</html>
